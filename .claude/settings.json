{
  "alwaysThinkingEnabled": true,
  "autoCompactEnabled": true,
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "figma@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "echo \"[$(date)] idle_prompt hook triggered\" >> /tmp/claude-hooks.log; ~/.zsh/claude-notify.sh '入力を待っています'",
            "type": "command"
          }
        ],
        "matcher": "idle_prompt"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/kitagry/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "echo \"[$(date)] Stop hook triggered\" >> /tmp/claude-hooks.log && ~/.zsh/claude-notify.sh 'タスクが完了しました'",
            "type": "command"
          }
        ]
      }
    ]
  },
  "language": "Japanese",
  "permissions": {
    "allow": [
      "Bash(git fetch *)",
      "Bash(git status *)",
      "Bash(git stash:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git blame:*)",
      "Bash(git ls-tree:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git describe:*)",
      "Bash(git shortlog:*)",
      "Bash(git reflog:*)",
      "Bash(git cat-file:*)",
      "Bash(git worktree:*)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh run view *)",
      "Bash(gh run rerun *)",
      "mcp__github__get_file_contents",
      "mcp__github__get_commit",
      "mcp__github__get_me",
      "mcp__github__get_label",
      "mcp__github__get_latest_release",
      "mcp__github__get_release_by_tag",
      "mcp__github__get_tag",
      "mcp__github__get_team_members",
      "mcp__github__get_teams",
      "mcp__github__list_branches",
      "mcp__github__list_commits",
      "mcp__github__list_issues",
      "mcp__github__list_issue_types",
      "mcp__github__list_pull_requests",
      "mcp__github__list_releases",
      "mcp__github__list_tags",
      "mcp__github__search_pull_requests",
      "mcp__github__search_issues",
      "mcp__github__search_code",
      "mcp__github__search_repositories",
      "mcp__github__search_users",
      "mcp__github__pull_request_read",
      "mcp__github__issue_read",
      "ReadMcpResourceTool(server=github)",
      "Bash(uv run ruff:*)",
      "Bash(uv run mypy:*)",
      "Bash(uv run tox:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv sync *)",
      "Bash(uv lock *)",
      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(grep *)",
      "Bash(golangci-lint run *)",
      "Bash(cargo build *)",
      "Bash(cargo test *)",
      "Bash(cargo check *)",
      "Bash(cargo clippy *)",
      "Bash(cargo fmt *)",
      "Bash(cargo run *)"
    ]
  },
  "preferredNotifChannel": "notifications_disabled",
  "skipWorkflowUsageWarning": true,
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "padding": 0,
    "type": "command"
  },
  "tui": "default",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true
}