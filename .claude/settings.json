{
  "env": {
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false"
  },
  "permissions": {
    "allow": [
      "Bash(git fetch *)",
      "Bash(git status *)",
      "Bash(git stash:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git blame:*)",
      "Bash(git ls-tree:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git describe:*)",
      "Bash(git shortlog:*)",
      "Bash(git reflog:*)",
      "Bash(git cat-file:*)",
      "Bash(git worktree:*)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh run view *)",
      "Bash(gh run rerun *)",
      "mcp__github__get_file_contents",
      "mcp__github__get_commit",
      "mcp__github__get_me",
      "mcp__github__get_label",
      "mcp__github__get_latest_release",
      "mcp__github__get_release_by_tag",
      "mcp__github__get_tag",
      "mcp__github__get_team_members",
      "mcp__github__get_teams",
      "mcp__github__list_branches",
      "mcp__github__list_commits",
      "mcp__github__list_issues",
      "mcp__github__list_issue_types",
      "mcp__github__list_pull_requests",
      "mcp__github__list_releases",
      "mcp__github__list_tags",
      "mcp__github__search_pull_requests",
      "mcp__github__search_issues",
      "mcp__github__search_code",
      "mcp__github__search_repositories",
      "mcp__github__search_users",
      "mcp__github__pull_request_read",
      "mcp__github__issue_read",
      "ReadMcpResourceTool(server=github)",
      "Bash(uv run ruff:*)",
      "Bash(uv run mypy:*)",
      "Bash(uv run tox:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv sync *)",
      "Bash(uv lock *)",
      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(grep *)",
      "Bash(golangci-lint run *)"
    ]
  },
  "model": "claude-opus-4-7",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -z \"$TMUX\" ] && exit 0; label=$(tmux display-message -t \"$TMUX_PANE\" -p '#{@claude_label}'); tmux select-pane -t \"$TMUX_PANE\" -T \"? ${label:-Claude Code}\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -z \"$TMUX\" ] && exit 0; label=$(tmux display-message -t \"$TMUX_PANE\" -p '#{@claude_label}'); tmux select-pane -t \"$TMUX_PANE\" -T \"✳ ${label:-Claude Code}\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/set-tmux-title.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date)] idle_prompt hook triggered\" >> /tmp/claude-hooks.log; ~/.zsh/claude-notify.sh '入力を待っています'; if [ -n \"$TMUX\" ]; then label=$(tmux display-message -t \"$TMUX_PANE\" -p '#{@claude_label}'); tmux select-pane -t \"$TMUX_PANE\" -T \"? ${label:-Claude Code}\"; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date)] Stop hook triggered\" >> /tmp/claude-hooks.log && ~/.zsh/claude-notify.sh 'タスクが完了しました' && ~/.claude/hooks/stop-tmux-title.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true,
    "lua-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "figma@claude-plugins-official": true
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "tui": "default",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipWorkflowUsageWarning": true,
  "preferredNotifChannel": "notifications_disabled",
  "autoCompactEnabled": true,
  "voiceEnabled": true
}
